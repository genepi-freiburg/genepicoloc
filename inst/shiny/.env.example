# Per-machine config for inst/shiny/deploy.sh (copy to .env, do not commit)

# Absolute path to the atlas root. Expected layout:
#   <GENEPICOLOC_DATA_PATH>/
#     <category>/coloc/<trait>.RDS
#     <category>/regional/<trait>/<region>.RDS
#     gene_annotation.tsv
#
# Local dev example:
# GENEPICOLOC_DATA_PATH=/home/you/Work/bioinfo/nextcloud/Downloads/genepicoloc/genepicoloc_atlas
#
# Remote deploy example:
# GENEPICOLOC_DATA_PATH=/srv/genepicoloc/atlas

GENEPICOLOC_DATA_PATH=

# Optional overrides (sensible defaults in deploy.sh)
# SHINY_PORT=3838
# CONTAINER_NAME=genepicoloc-shiny
# IMAGE_NAME=genepicoloc-shiny

# Anthropic API key for the in-app AI chat (ellmer)
ANTHROPIC_API_KEY=
